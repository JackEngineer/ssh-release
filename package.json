{
  "name": "ssh-release",
  "version": "0.1.0",
  "description": "A general-purpose SSH file release CLI.",
  "type": "module",
  "bin": {
    "ssh-release": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
